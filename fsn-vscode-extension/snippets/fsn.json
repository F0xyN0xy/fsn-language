{
  "Let Variable": { "prefix": "let", "body": ["let ${1:name} be ${2:value}."], "description": "Declare a variable" },
  "Set Variable": { "prefix": "set", "body": ["set ${1:name} to ${2:value}."], "description": "Update a variable" },
  "Say": { "prefix": "say", "body": ["say ${1:\"message\"}."], "description": "Print to console" },
  "Ask Input": { "prefix": "ask", "body": ["ask \"${1:prompt}\" and store it in ${2:variable}."], "description": "Ask user for input" },
  "If Statement": { "prefix": "if", "body": ["if ${1:condition} then", "  ${2:say \"yes\".}", "otherwise", "  ${3:say \"no\".}", "end if."], "description": "If/otherwise block" },
  "If Only": { "prefix": "ifo", "body": ["if ${1:condition} then", "  ${2:say \"yes\".}", "end if."], "description": "If block without otherwise" },
  "Repeat Loop": { "prefix": "repeat", "body": ["repeat ${1:5} times", "  ${2:say \"hello\".}", "end repeat."], "description": "Count-based loop" },
  "Keep Doing While": { "prefix": "keep", "body": ["keep doing while ${1:count} is less than ${2:10}", "  ${3:say count.}", "  set ${1:count} to ${1:count} plus 1.", "end keep."], "description": "While loop" },
  "For Each": { "prefix": "foreach", "body": ["for each ${1:item} in ${2:list}", "  say ${1:item}.", "end for."], "description": "For-each loop" },
  "Define Function": { "prefix": "define", "body": ["define ${1:function name} with ${2:param}", "  ${3:say param.}", "end define."], "description": "Define a function" },
  "Define Function No Params": { "prefix": "definenp", "body": ["define ${1:function name}", "  ${2:say \"running\".}", "end define."], "description": "Define a function with no parameters" },
  "Call Function": { "prefix": "call", "body": ["call ${1:function name} with ${2:arg}."], "description": "Call a function" },
  "Give Back": { "prefix": "giveback", "body": ["give back ${1:value}."], "description": "Return a value" },
  "List Declaration": { "prefix": "list", "body": ["let ${1:items} be a list of ${2:\"a\"}, ${3:\"b\"}."], "description": "Create a list" },
  "Add To List": { "prefix": "add", "body": ["add ${1:value} to ${2:list}."], "description": "Add item to list" },
  "Remove From List": { "prefix": "remove", "body": ["remove ${1:value} from ${2:list}."], "description": "Remove item from list" },
  "Sort List": { "prefix": "sort", "body": ["sort ${1:list}."], "description": "Sort a list" },
  "Shuffle List": { "prefix": "shuffle", "body": ["shuffle ${1:list}."], "description": "Shuffle a list" },
  "Note Comment": { "prefix": "note", "body": ["note ${1:your comment here}"], "description": "Add a comment" },
  "Result Of Function": { "prefix": "result", "body": ["let ${1:result} be the result of ${2:function name} with ${3:arg}."], "description": "Store function return value" },
  "Square Root": { "prefix": "sqrt", "body": ["let ${1:result} be the square root of ${2:number}."], "description": "Square root" },
  "Power": { "prefix": "pow", "body": ["let ${1:result} be ${2:base} to the power of ${3:exp}."], "description": "Power/exponent" },
  "Uppercase": { "prefix": "upper", "body": ["let ${1:result} be the uppercase of ${2:text}."], "description": "Convert to uppercase" },
  "Lowercase": { "prefix": "lower", "body": ["let ${1:result} be the lowercase of ${2:text}."], "description": "Convert to lowercase" },
  "Replace Text": { "prefix": "replace", "body": ["let ${1:result} be ${2:text} with \"${3:old}\" replaced by \"${4:new}\"."], "description": "Replace in text" },
  "Split Text": { "prefix": "split", "body": ["let ${1:parts} be ${2:text} split by \"${3: }\"."], "description": "Split text into list" },
  "Join List": { "prefix": "join", "body": ["let ${1:result} be ${2:list} joined with \"${3:, }\"."], "description": "Join list into text" },
  "Random Number": { "prefix": "rand", "body": ["let ${1:n} be a random number between ${2:1} and ${3:100}."], "description": "Random number" },
  "Random Choice": { "prefix": "choice", "body": ["let ${1:pick} be a random choice from ${2:list}."], "description": "Random choice from list" },
  "Current Date": { "prefix": "date", "body": ["let ${1:today} be the current date."], "description": "Get current date" },
  "Current Time": { "prefix": "time", "body": ["let ${1:now} be the current time."], "description": "Get current time" },
  "Write File": { "prefix": "write", "body": ["write ${1:content} to file \"${2:filename.txt}\"."], "description": "Write to file" },
  "Append File": { "prefix": "append", "body": ["append ${1:content} to file \"${2:filename.txt}\"."], "description": "Append to file" },
  "Read File": { "prefix": "read", "body": ["read file \"${1:filename.txt}\" and store it in ${2:contents}."], "description": "Read a file" },
  "Show Window": { "prefix": "window", "body": ["show window titled \"${1:My App}\" with width ${2:400}, height ${3:300}."], "description": "Create a GUI window" },
  "Show Label": { "prefix": "label", "body": ["show label \"${1:Hello!}\"."], "description": "Add a label to window" },
  "Show Button": { "prefix": "button", "body": ["show button \"${1:Click Me}\"."], "description": "Add a button to window" },
  "Show Input": { "prefix": "input", "body": ["show input stored in ${1:answer}."], "description": "Add an input field" },
  "Show Popup": { "prefix": "popup", "body": ["show popup \"${1:message}\"."], "description": "Show a popup dialog" },
  "Display Window": { "prefix": "display", "body": ["display window."], "description": "Show and run the window" }
}
